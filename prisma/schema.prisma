// Prisma schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Flashcard {
  id               Int      @id @default(autoincrement())
  
  // --- THÔNG TIN ĐỊNH DANH ---
  indexCode        String?  // Mã mục lục theo tài liệu (VD: "1.1.1")
  category         String   // Phân loại (VD: "tu_nhien", "tong_hop")
  name             String   // Tên chính (VD: "Cây thuốc phiện")
  scientificName   String?  // Tên khoa học (VD: "Papaver somniferum L.")
  otherNames       String?  // Tên khác / Tiếng lóng (VD: "Cây Anh túc, A phiến...")
  
  // --- THÔNG TIN HIỂN THỊ CƠ BẢN ---
  imageUrl         String?  // URL ảnh minh họa
  shortDesc        String?  // Mô tả ngắn gọn cho mặt trước/sau của thẻ
  
  // --- THÔNG TIN CHI TIẾT (Bóc tách từ file Word) ---
  concept          String?  // Khái niệm chung (nếu có)
  origin           String?  // Nguồn gốc, lịch sử xuất hiện
  distribution     String?  // Nơi gieo trồng, vùng phân bố (để tách biệt với lịch sử)
  identification   String[] // Cách nhận biết (Lưu mảng String để dễ map ra thẻ <ul> <li>)
  harmfulEffects   String[] // Tác hại (Lưu mảng String)
  
  // --- METADATA ---
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model LawNode {
  id        String   @id @default(cuid())
  article   String   // Ví dụ: Điều 251
  name      String   // Tên tội danh
  x         String   // Tọa độ X trên cây
  y         String   // Tọa độ Y trên cây
  details   Json     // Lưu mảng các khung hình phạt (JSON)
  createdAt DateTime @default(now())
}