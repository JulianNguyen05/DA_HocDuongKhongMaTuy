// Prisma schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Flashcard {
  id               Int      @id @default(autoincrement())
  
  // --- THÔNG TIN ĐỊNH DANH ---
  indexCode        String?  // Mã mục lục theo tài liệu (VD: "1.1.1")
  category         String   // Phân loại (VD: "tu_nhien", "tong_hop")
  name             String   // Tên chính (VD: "Cây thuốc phiện")
  scientificName   String?  // Tên khoa học (VD: "Papaver somniferum L.")
  otherNames       String?  // Tên khác / Tiếng lóng (VD: "Cây Anh túc, A phiến...")
  
  // --- THÔNG TIN HIỂN THỊ CƠ BẢN ---
  imageUrl         String?  // URL ảnh minh họa
  shortDesc        String?  // Mô tả ngắn gọn cho mặt trước/sau của thẻ
  
  // --- THÔNG TIN CHI TIẾT (Bóc tách từ file Word) ---
  concept          String?  // Khái niệm chung (nếu có)
  origin           String?  // Nguồn gốc, lịch sử xuất hiện
  distribution     String?  // Nơi gieo trồng, vùng phân bố (để tách biệt với lịch sử)
  identification   String[] // Cách nhận biết (Lưu mảng String để dễ map ra thẻ <ul> <li>)
  harmfulEffects   String[] // Tác hại (Lưu mảng String)
  
  // --- METADATA ---
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// 1. Cấp độ cao nhất: ĐIỀU LUẬT (Ví dụ: Điều 247)
model LawArticle {
  id          String       @id @default(cuid())
  articleNum  String       // Số điều (VD: "247")
  name        String       // Tên tội danh (VD: "Tội trồng cây thuốc phiện...")
  
  // Tọa độ phục vụ cho UI vẽ Node/Mindmap
  x           Float        
  y           Float        
  
  // Quan hệ 1-n: 1 Điều có nhiều Khoản
  clauses     LawClause[]  
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// 2. Cấp độ 2: KHOẢN (Các khung hình phạt - VD: Khoản 1, 2, 3...)
model LawClause {
  id               String       @id @default(cuid())
  articleId        String
  article          LawArticle   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  
  clauseNum        Int          // Số khoản (VD: 1, 2, 3, 4)
  penaltySummary   String       // Tóm tắt hình phạt (VD: "phạt tù từ 06 tháng đến 03 năm")
  isAdditional     Boolean      @default(false) // Đánh dấu nếu là hình phạt bổ sung (VD: "Người phạm tội còn có thể bị phạt tiền...")
  
  // Quan hệ 1-n: 1 Khoản có nhiều Điểm (tình tiết)
  points           LawPoint[]   
  
  createdAt        DateTime     @default(now())
}

// 3. Cấp độ 3: ĐIỂM (Các tình tiết định khung - VD: Điểm a, b, c...)
model LawPoint {
  id          String       @id @default(cuid())
  clauseId    String
  clause      LawClause    @relation(fields: [clauseId], references: [id], onDelete: Cascade)
  
  pointLetter String?      // Ký hiệu điểm (VD: "a", "b", "c"). Có thể null nếu Khoản đó không chia Điểm
  content     String       // Nội dung tình tiết (VD: "Có tổ chức", "Tái phạm nguy hiểm")
  
  createdAt   DateTime     @default(now())
}